{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/sanity-proxy/api/(.*)", "destination": "/api/serverless" },
    { "source": "/sanity-proxy/cdn/(.*)", "destination": "/api/serverless" },
    { "source": "/api/(.*)", "destination": "/api/serverless" },
    { "source": "/admin", "destination": "/api/serverless" },
    { "source": "/admin/(.*)", "destination": "/api/serverless" },
    { "source": "/static/(.*)", "destination": "/static/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
